import {
    VerticalBox,
    HorizontalBox,
    ScrollView,
    ListView,
} from "std-widgets.slint";

export enum AppMode {
    Root,
    Emoji,
    Clipboard,
}

export struct SearchResult {
    name: string,
    exec: string,
    icon: image,
}

export struct EmojiResult {
    character: string,
    name: string,
    row: int,
    col: int,
    orig_index: int,
}

export struct EmojiCategory {
    name: string,
    count: int,
    emojis: [EmojiResult],
}

export struct ClipboardResult {
    content: string,
}

export component AppWindow inherits Window {
    // Input properties
    in-out property <string> search_text: "";
    // State properties
    in-out property <AppMode> active_mode: AppMode.Root;
    in property <[SearchResult]> results: [];
    in property <[EmojiCategory]> emoji_categories: [];
    in property <[ClipboardResult]> clipboard_results: [];
    in-out property <int> selected_index: 0;
    in-out property <length> current_scroll_y: 0px;
    // Which category group to show in the single-category emoji view (0-based)
    in-out property <int> current_group_index: 0;

    // Callbacks
    callback text-changed(string);
    callback item-activated(int);
    callback next-item();
    callback prev-item();
    callback execute-selected();
    callback pop-mode();
    callback nav-up();
    callback nav-down();
    callback nav-left();
    callback nav-right();
    callback update-scroll(float);
    callback cycle-group();  // Ctrl+T → next category group

    no-frame: true;
    background: transparent;
    forward-focus: search_input;

    // Chameleon behavior: Base height of 106px
    // Variable list heights depending on mode
    property <length> list_height: root.active_mode == AppMode.Root ? min(results.length * 54px, 400px) : root.active_mode == AppMode.Emoji ? 400px : // Keep fixed size for FlowLayout scrolling
                                   min(clipboard_results.length * 54px, 400px);

    height: search_text == "" && root.active_mode == AppMode.Root ? 106px : 107px + list_height;
    width: 650px;
    
    // Main Container with Glassmorphism and rounded corners
    Rectangle {
        border-radius: 12px;
        background: #1e1e2ef3; // Semi-transparent dark Mocha base
        border-width: 1px;
        border-color: #313244;
        clip: true; // keep corners rounded

        VerticalBox {
            padding: 0;
            spacing: 0;

            // Header: Search Bar
            Rectangle {
                height: 65px;
                background: transparent;

                HorizontalBox {
                    padding: 0;
                    spacing: 0;

                    // Conditional Back Button
                    if root.active_mode != AppMode.Root: Rectangle {
                        width: 48px;
                        height: 65px;
                        Text {
                            text: "⬅";
                            font-size: 20px;
                            color: #cdd6f4;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: 100%;
                            height: 100%;
                        }

                        TouchArea {
                            clicked => {
                                root.pop-mode();
                            }
                        }
                    }

                    // Search icon — always visible, vertically centred
                    Text {
                        text: root.active_mode == AppMode.Emoji ? "😀" : root.active_mode == AppMode.Clipboard ? "📋" : "🔍";
                        font-size: 20px;
                        width: 44px;
                        height: 65px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    // Input area: TextInput + simulated placeholder overlay
                    Rectangle {
                        width: parent.width - 44px - (root.active_mode != AppMode.Root ? 48px : 0px) - 16px;
                        height: 65px;

                        search_input := TextInput {
                            width: 100%;
                            height: 100%;
                            font-size: 22px;
                            color: #cdd6f4;
                            vertical-alignment: center;
                            text <=> root.search_text;
                            single-line: true;

                            // Request focus immediately upon mapping
                            init => {
                                self.focus();
                            }

                            edited => {
                                root.selected_index = 0;
                                root.text-changed(self.text);
                            }
                            accepted => {
                                root.execute-selected();
                            }

                            key-pressed(event) => {
                                if (event.text == Key.Escape) {
                                    if (root.active_mode != AppMode.Root) {
                                        root.pop-mode();
                                        return accept;
                                    } else {
                                        return reject;
                                    }
                                }
                                if (event.text == Key.UpArrow) {
                                    if (root.active_mode == AppMode.Emoji) {
                                        root.nav-up();
                                    } else {
                                        root.selected_index = max(0, root.selected_index - 1);
                                    }
                                    return accept;
                                }
                                if (event.text == Key.DownArrow) {
                                    if (root.active_mode == AppMode.Emoji) {
                                        root.nav-down();
                                    } else {
                                        let max_idx = root.active_mode == AppMode.Root ? max(0, root.results.length - 1) : max(0, root.clipboard_results.length - 1);
                                        root.selected_index = min(max_idx, root.selected_index + 1);
                                    }
                                    return accept;
                                }
                                if (event.text == Key.LeftArrow) {
                                    if (root.active_mode == AppMode.Emoji) {
                                        root.nav-left();
                                        return accept;
                                    }
                                }
                                if (event.text == Key.RightArrow) {
                                    if (root.active_mode == AppMode.Emoji) {
                                        root.nav-right();
                                        return accept;
                                    }
                                }
                                // Ctrl+T → cycle to next emoji category group
                                if (event.text == "t" && event.modifiers.control) {
                                    if (root.active_mode == AppMode.Emoji) {
                                        root.cycle-group();
                                        return accept;
                                    }
                                }
                                return reject;
                            }
                        }

                        // Simulated placeholder: shown when search text is empty
                        if root.search_text == "": Text {
                            x: 0;
                            y: 0;
                            width: 100%;
                            height: 100%;
                            text: root.active_mode == AppMode.Emoji ? "Search Emoji..." : root.active_mode == AppMode.Clipboard ? "Search Clipboard..." : "Type to Search...";
                            color: #45475a;
                            font-size: 22px;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            // Rest of the UI follows
            Rectangle {
                height: 1px;
                background: #313244; // Divider
            }

            // Middle: Scrollable Results container
            Rectangle {
                height: search_text == "" && root.active_mode == AppMode.Root ? 0px : root.list_height;
                clip: true; // clip ensures it vanishes completely without overflow
                
                scroll := ScrollView {
                    height: 100%;
                    width: 100%;
                    // viewport-height tells the ScrollView how tall the content is so the scrollbar appears.
                    // For emoji mode we estimate: each category ~400px; for lists: row count * 54px.
                    viewport-height: root.active_mode == AppMode.Emoji ? max(root.list_height + 1px, root.emoji_categories.length * 400px) : root.active_mode == AppMode.Root ? root.results.length * 54px : root.clipboard_results.length * 54px;
                    
                    // APP SEARCH UI
                    if root.active_mode == AppMode.Root: VerticalBox {
                        alignment: start;
                        spacing: 4px;

                        for result[i] in root.results: Rectangle {
                            height: 50px;
                            background: i == root.selected_index ? #89b4fa40 : transparent; // Highlight
                            border-radius: 8px;

                            HorizontalBox {
                                padding-left: 12px;
                                padding-right: 12px;
                                spacing: 12px;
                                
                                // App Icon
                            Image {
                                    source: result.icon;
                                    width: 24px;
                                    height: 24px;
                                    vertical-alignment: center;
                                }
                            
                            // App Name
                            Text {
                                    text: result.name;
                                    color: i == root.selected_index ? #cdd6f4 : #bac2de;
                                    font-size: 16px;
                                    font-weight: i == root.selected_index ? 600 : 400;
                                    vertical-alignment: center;
                                }
                            }

                            TouchArea {
                                clicked => {
                                    root.selected_index = i;
                                    root.execute-selected();
                                }
                            }
                        }
                    }

                    // EMOJI UI — single-category view, Ctrl+T cycles groups
                    if root.active_mode == AppMode.Emoji: VerticalBox {
                        alignment: start;
                        padding-top: 12px;
                        padding-bottom: 16px;
                        spacing: 12px;

                        // ── Group badge: name pill + counter + Ctrl+T hint ──
                        HorizontalBox {
                            padding-left: 14px;
                            padding-right: 14px;
                            alignment: start;
                            spacing: 10px;

                            // Active group name pill
                            Rectangle {
                                border-radius: 6px;
                                background: #313244;
                                height: 26px;
                                HorizontalBox {
                                    padding-left: 10px;
                                    padding-right: 10px;
                                    Text {
                                        text: root.emoji_categories.length > 0 ? root.emoji_categories[root.current_group_index].name : "";
                                        color: #cdd6f4;
                                        font-size: 13px;
                                        font-weight: 700;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // Emoji count badge
                            Rectangle {
                                border-radius: 6px;
                                background: #1e1e2e;
                                height: 26px;
                                HorizontalBox {
                                    padding-left: 8px;
                                    padding-right: 8px;
                                    Text {
                                        text: root.emoji_categories.length > 0 ? root.emoji_categories[root.current_group_index].count : "";
                                        color: #6c7086;
                                        font-size: 13px;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // Spacer
                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            // Ctrl+T hint
                            Text {
                                text: "Ctrl+T to switch";
                                color: #45475a;
                                font-size: 11px;
                                vertical-alignment: center;
                            }
                        }

                        // ── Active category grid ──
                        if root.emoji_categories.length > 0: Rectangle {
                            height: ceil(root.emoji_categories[root.current_group_index].emojis.length / 7) * 85px;

                            for result[i] in root.emoji_categories[root.current_group_index].emojis: Rectangle {
                                x: (mod(i, 7)) * 90px + 10px;
                                y: floor(i / 7) * 85px;
                                width: 75px;
                                height: 75px;
                                background: result.orig_index == root.selected_index ? #89b4fa40 : #1b2331;
                                border-radius: 8px;
                                border-width: 2px;
                                border-color: result.orig_index == root.selected_index ? #89b4fa : #283448;

                                Text {
                                    text: result.character;
                                    font-size: 50px;
                                    font-family: "Noto Color Emoji";
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    width: 100%;
                                    height: 100%;
                                }

                                TouchArea {
                                    clicked => {
                                        root.selected_index = result.orig_index;
                                        root.execute-selected();
                                    }
                                }
                            }
                        }
                    }

                    // CLIPBOARD UI
                    if root.active_mode == AppMode.Clipboard: VerticalBox {
                        alignment: start;
                        spacing: 4px;

                        for result[i] in root.clipboard_results: Rectangle {
                            height: 50px;
                            background: i == root.selected_index ? #89b4fa40 : transparent;
                            border-radius: 8px;

                            HorizontalBox {
                                padding-left: 12px;
                                padding-right: 12px;
                                spacing: 12px;
                                Text {
                                    text: result.content;
                                    color: i == root.selected_index ? #cdd6f4 : #bac2de;
                                    font-size: 14px;
                                    font-weight: i == root.selected_index ? 600 : 400;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                            }

                            TouchArea {
                                clicked => {
                                    root.selected_index = i;
                                    root.execute-selected();
                                }
                            }
                        }
                    }
                }
            }

            Rectangle {
                height: root.search_text == "" ? 0px : 1px;
                background: #313244; // Divider
                clip: true;
            }

            // Footer: Commands
                Rectangle {
                height: 40px;
                background: #181825c0; // Slightly darker and more transparent
                    
                    HorizontalBox {
                    padding-left: 16px;
                    padding-right: 16px;
                    Text {
                        text: root.active_mode == AppMode.Emoji ? "Show Details" : root.active_mode == AppMode.Root ? "App Indexer v1 ❄" : "Clipboard History 📋";
                        color: #a6adc8;
                        font-size: 12px;
                        vertical-alignment: center;
                    }

                    Text {
                        text: root.active_mode == AppMode.Emoji ? "Enter ↵ to Copy" : "Type to Search • Enter to Open";
                        color: #6c7086;
                        font-size: 12px;
                        vertical-alignment: center;
                        horizontal-alignment: right;
                    }
                }
            }
        }
    }
    
    // update-scroll: Rust calls this after key navigation to keep the selected emoji visible.
    // Writes scroll.viewport-y directly so mouse-wheel scrolling works freely between keystrokes.
    update-scroll(target_y) => {
        let tgt = target_y * 1px;
        let item_bot = tgt + 85px;
        let view_top = 0px - scroll.viewport-y;
        let view_bot = view_top + scroll.height;

        if (tgt < view_top) {
            // Item above visible area → scroll up
            scroll.viewport-y = 0px - tgt + 8px;
        } else if (item_bot > view_bot) {
            // Item below visible area → scroll down
            scroll.viewport-y = 0px - (item_bot - scroll.height) - 8px;
        }
    }
}
